rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAllowedTrip(tripId) {
      return tripId == "vietnam-2026-da-nang";
    }

    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isTripMember(tripId) {
      return isAllowedTrip(tripId)
        && signedIn()
        && firestore.exists(/databases/(default)/documents/trips/$(tripId)/members/$(request.auth.token.email));
    }

    function isAllowedUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|application/pdf");
    }

    match /trips/{tripId}/{allPaths=**} {
      allow read: if isTripMember(tripId);
      allow write: if isTripMember(tripId) && isAllowedUpload();
    }
  }
}
